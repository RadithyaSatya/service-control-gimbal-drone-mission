# Backend HTTP base URL used for WS token retrieval and media upload/register APIs.
API_BASE_URL=http://127.0.0.1:8081

# Optional explicit WebSocket base URL.
# If empty in real config, the service derives /ws/telemetry from API_BASE_URL.
WS_URL=ws://127.0.0.1:8081

# Device token used by this bridge to authenticate to backend APIs and WebSocket token endpoint.
DEVICE_TOKEN=uav-local-dev-token

# UAV identifier used for WS subscribe/publish routing.
UAV_ID=1

# MAVLink endpoint listened by this bridge for gimbal telemetry/control integration.
MAVLINK_ENDPOINT=udpin:0.0.0.0:14560

# MAVLink source identity used when this bridge sends commands.
MAVLINK_SOURCE_SYSTEM=250
MAVLINK_SOURCE_COMPONENT=191

# MAVLink target gimbal identity used for DO_GIMBAL_MANAGER_PITCHYAW.
MAVLINK_GIMBAL_SYSTEM=1
MAVLINK_GIMBAL_COMPONENT=1
MAVLINK_GIMBAL_DEVICE_ID=0

# Realtime metric name for inbound gimbal commands from backend/frontend.
GIMBAL_COMMAND_METRIC=gimbal_command

# Realtime metric name for outbound gimbal state published by this bridge.
GIMBAL_STATE_METRIC=gimbal_state

# Minimum interval in seconds between repeated gimbal state publishes with unchanged payload.
GIMBAL_STATE_INTERVAL_SECONDS=1.0

# If no gimbal MAVLink status is received within this timeout, bridge publishes connected=false.
GIMBAL_CONNECTED_TIMEOUT_SECONDS=5.0

# Enable SIYI camera support in this bridge.
SIYI_ENABLED=true

# SIYI camera UDP control IP address.
SIYI_IP=192.168.144.25

# SIYI camera UDP control port.
SIYI_PORT=37260

# Max wait time for each SIYI SDK connect attempt.
SIYI_CONNECT_MAX_WAIT_TIME=3.0

# Number of SIYI SDK connect retries before giving up for that cycle.
SIYI_CONNECT_MAX_RETRIES=3

# Delay before retrying SIYI reconnect from background camera state loop.
SIYI_RECONNECT_DELAY_SECONDS=5.0

# Realtime metric name for inbound camera commands from backend/frontend.
CAMERA_COMMAND_METRIC=camera_command

# Realtime metric name for outbound camera state published by this bridge.
CAMERA_STATE_METRIC=camera_state

# Minimum interval in seconds between repeated camera state publishes with unchanged payload.
CAMERA_STATE_INTERVAL_SECONDS=1.0

# Delay before retrying backend HTTP/WS connect after failure.
BACKEND_CONNECT_RETRY_SECONDS=5.0

# Enable camera actions triggered by waypoint mission_event payloads such as take picture / record video.
MISSION_EVENT_CAMERA_ACTIONS_ENABLED=true

# Realtime metric name used for inbound and outbound mission events.
MISSION_EVENT_METRIC=mission_event

# Enable post-landing media processing flow.
# If false, this service ignores mission_event "media_processing_requested".
MISSION_POST_LANDING_MEDIA_ENABLED=false

# Enable downloading SIYI camera media after post-landing trigger.
# Required for delivery modes "upload" and "register_move".
MISSION_POST_LANDING_MEDIA_DOWNLOAD_ENABLED=true

# Enable SD card formatting after post-landing trigger.
# This can still run even if some downloads fail.
MISSION_POST_LANDING_MEDIA_FORMAT_ENABLED=true

# Total timeout budget in seconds for the whole post-landing media flow.
# This should match the timeout expected by the mission/docking service.
MISSION_POST_LANDING_MEDIA_TIMEOUT_SEC=120

# Delivery mode after local download is complete:
# - local_only: keep files only in this repo under ./downloads/history-{history_id}/media
# - upload: upload each file to backend endpoint /mission-history/{history_id}/media/upload
# - register_move: move files into MISSION_CAMERA_MEDIA_REGISTER_ROOT/history-{history_id}/media
#                  then register them via /mission-history/{history_id}/media/register
MISSION_CAMERA_MEDIA_DELIVERY_MODE=local_only

# Base directory used only by delivery mode "register_move".
# Must point to the backend mission media root, for example /data/missions
# or a local dev path like /path/to/be-drone-mission/data/missions
MISSION_CAMERA_MEDIA_REGISTER_ROOT=
